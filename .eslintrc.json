{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "d3": "readonly",
    "L": "readonly",
    "RadialChart": "readonly"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["error", { "varsIgnorePattern": "^[A-Z]" }]
  }
}
